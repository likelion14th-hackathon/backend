SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local

MYSQL_PORT=3306
MYSQL_DATABASE=todays_casting
MYSQL_USER=todays
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me

TZ=Asia/Seoul

# For running the Spring Boot app from IntelliJ while using Docker MySQL.
# Match the port to MYSQL_PORT above.
DB_URL=jdbc:mysql://localhost:3306/todays_casting?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=todays
DB_PASSWORD=change-me
